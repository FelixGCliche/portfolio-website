{
  "name": "tanstack-router-file-based",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "vite build",
    "serve": "vite preview",
    "start": "vite",
    "check": "tsc --noEmit && oxlint && oxfmt",
    "check:type": "tsc --noEmit",
    "check:lint": "oxlint",
    "check:format": "oxfmt --check",
    "fix:lint": "oxlint --fix",
    "fix:format": "oxfmt",
    "deploy": "bun run build && wrangler deploy",
    "preview": "bun run build && wrangler dev"
  },
  "dependencies": {
    "@tanstack/router-plugin": "^1.131.35",
    "@tanstack/solid-router": "^1.131.35",
    "@tanstack/solid-router-devtools": "^1.131.35",
    "redaxios": "^0.5.1",
    "solid-js": "^1.9.9",
    "tailwindcss": "^4.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "solid-devtools": "^0.34.3",
    "typescript": "^5.9.2",
    "vite": "^7.1.10",
    "vite-plugin-solid": "^2.11.9",
    "wrangler": "^4.94.0"
  }
}
